{
  "version": 2,
  "crons": [
    { "path": "/api/cron/job-hunt", "schedule": "0 5 * * *" },
    { "path": "/api/cron/job-hunt", "schedule": "0 6 * * *" }
  ],
  "functions": {
    "api/claude.js": { "maxDuration": 60 },
    "api/search.js": { "maxDuration": 30 },
    "api/util.js": { "maxDuration": 30 },
    "api/get-agent-results.js": { "maxDuration": 60 },
    "api/cron/job-hunt.js": { "maxDuration": 60 },
    "api/ai.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/gemini", "dest": "/api/ai.js?fn=gemini" },
    { "src": "/api/transcribe", "dest": "/api/ai.js?fn=transcribe" },
    { "src": "/api/backup", "dest": "/api/ai.js?fn=backup" },
    { "src": "/api/vapid-public", "dest": "/api/ai.js?fn=vapid-public" },
    { "src": "/api/push-subscribe", "dest": "/api/ai.js?fn=push-subscribe" },
    { "src": "/api/restore", "dest": "/api/ai.js?fn=restore" },
    { "src": "/api/jobs-get", "dest": "/api/ai.js?fn=jobs_get" },
    { "src": "/api/jobs-put", "dest": "/api/ai.js?fn=jobs_put" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/fetch-page", "dest": "/api/util.js?fn=fetch-page" },
    { "src": "/api/log-error", "dest": "/api/util.js?fn=log-error" },
    { "src": "/api/google-callback", "dest": "/api/google-callback.js" },
    { "src": "/api/whatsapp-command", "dest": "/api/whatsapp-command.js" },
    { "src": "/api/whatsapp/send", "dest": "/api/util.js?fn=send" },
    { "src": "/api/cron/job-hunt", "dest": "/api/cron/job-hunt.js" },
    { "src": "/api/news-digest", "dest": "/api/util.js?fn=news-digest" },
    { "src": "/api/get-agent-results", "dest": "/api/get-agent-results.js" },
    { "src": "/api/job-coach", "dest": "/api/ai.js?fn=coach" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/voice-hotspot", "dest": "/showcase/voice-hotspot.html" },
    { "src": "/icon.svg", "dest": "/icon.svg" },
    { "src": "/agent.js", "dest": "/agent.js" },
    { "src": "/assistant.js", "dest": "/assistant.js" },
    { "src": "/voice.js", "dest": "/voice.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
