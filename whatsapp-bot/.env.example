# ── Zoro WhatsApp bot — WhatsApp Cloud API ───────────────────────────────────
# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Cloud API (from developers.facebook.com → your App → WhatsApp)
WHATSAPP_TOKEN=            # permanent System User access token
PHONE_NUMBER_ID=           # WhatsApp → API Setup → "Phone number ID"
VERIFY_TOKEN=zoro-verify   # any string you choose — must match the webhook config in Meta
OWNER_WAID=972543329092    # your WhatsApp number, digits only — the only number the bot answers

# Optional — for reminders that fire >24h after your last message
REMINDER_TEMPLATE=         # name of an approved utility template (e.g. "reminder")
TEMPLATE_LANG=he

# Misc
PERSONAL_OS_URL=https://personal-os-coral-tau.vercel.app
DATA_DIR=/data             # Railway volume — reminders + state persist here
GRAPH_VERSION=v21.0
# PORT is provided automatically by Railway
